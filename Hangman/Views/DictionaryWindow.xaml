<mah:MetroWindow
    x:Class="Hangman.Views.DictionaryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Hangman.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPack="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Modern"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Hangman"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mycntr="clr-namespace:Hangman.UserControls"
    Title="Wisielec - Dictionary"
    Width="1020"
    Height="690"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="600" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!--  ROW 0  -->
        <TextBlock Style="{StaticResource OrangeTBNormal}" Text="Dictionary name:" />
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            Style="{StaticResource OrangeTBox}" />

        <!--  ROW I  -->
        <TextBlock
            Grid.Row="1"
            Style="{StaticResource OrangeTBNormal}"
            Text="Word:" />
        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Style="{StaticResource OrangeTBox}" />


        <!--  ROW II  -->
        <TextBlock
            Grid.Row="2"
            Style="{StaticResource OrangeTBNormal}"
            Text="Explanation:" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Height="465"
            AcceptsReturn="True"
            Style="{StaticResource OrangeTBox}"
            TextWrapping="Wrap" />


        <!--  ROW III  -->
        <TextBlock
            Grid.Row="3"
            Style="{StaticResource OrangeTBNormal}"
            Text="Speech part:" />
        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            Style="{StaticResource OrangeTBox}" />


    </Grid>
</mah:MetroWindow>
