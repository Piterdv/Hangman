<UserControl
    x:Class="Hangman.UserControls.PdvButtonBig"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Hangman.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="root">

    <Button
        Width="150"
        Command="{Binding ElementName=root, Path=ButtonClickCommand}"
        Style="{DynamicResource MetroButton}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="BigLetter"
                Style="{StaticResource OrangeTBBg}"
                Text="N" />
            <TextBlock
                x:Name="BtnText"
                Grid.Column="1"
                Width="117"
                Margin="3,2,0,0"
                HorizontalAlignment="Left"
                FontSize="12"
                FontWeight="Light"
                Style="{StaticResource OrangeTBNormal}"
                Text="Create new dictionary"
                TextAlignment="Left" />
        </Grid>
    </Button>
</UserControl>

